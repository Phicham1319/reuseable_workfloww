generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workflow {
  id        String   @id @default(cuid())
  name      String
  graph     Json
  createdAt DateTime @default(now())
  runs      Run[]
}
model Run {
  id         String    @id @default(cuid())
  workflowId String
  workflow   Workflow  @relation(fields: [workflowId], references: [id])
  status     String
  trigger    String
  startedAt  DateTime  @default(now())
  nodeRuns   NodeRun[]
}
model NodeRun {
  id        String   @id @default(cuid())
  runId     String
  run       Run      @relation(fields: [runId], references: [id])
  nodeId    String
  status    String
  input     Json?
  output    Json?
  error     String?
  createdAt DateTime @default(now())
}